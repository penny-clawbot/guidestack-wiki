---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
const siteConfig = JSON.parse(fs.readFileSync('site-config.json','utf-8'));
const niches = siteConfig.niches || [];
const cd = 'src/content/articles';
interface Art { title:string; description:string; slug:string; date:string; category:string; readingTime:string; tags:string[]; niche:string; }
function load(): Art[] {
  const a: Art[] = [];
  if (!fs.existsSync(cd)) return a;
  for (const f of fs.readdirSync(cd).filter((x:string)=>x.endsWith('.md'))) {
    const c = fs.readFileSync(path.join(cd,f),'utf-8');
    const fm: Record<string,any> = {}; const m = c.match(/^---\n([\s\S]*?)\n---/);
    if (m) { m[1].split('\n').forEach((l:string)=>{const x=l.match(/^(\w+):\s*["']?(.+?)["']?\s*$/);if(x)fm[x[1]]=x[2]}); if(typeof fm.tags==='string')fm.tags=fm.tags.split(',').map((t:string)=>t.trim()); }
    a.push({title:fm.title||f,description:fm.description||'',slug:f.replace(/\.md$/,'').replace(/^([^-]+-){2}\d{4}-\d{2}-\d{2}-(ai-)?/,''),date:fm.date||'',category:fm.category||'general',readingTime:fm.readingTime||'',tags:fm.tags||[],niche:f.match(/^([^-]+-[^-]+)-/)?.[1]||fm.niche||'general'});
  }
  return a;
}
export function getStaticPaths() {
  const sc = JSON.parse(fs.readFileSync('site-config.json','utf-8'));
  return sc.niches.map((n:any)=>({params:{niche:n.id},props:{nicheId:n.id}}));
}
const { nicheId } = Astro.props;
const nc = niches.find((n:any)=>n.id===nicheId);
const articles = load().filter(a=>a.niche===nicheId).sort((a,b)=>b.date.localeCompare(a.date));
const catMap = new Map<string,number>(); articles.forEach(a=>catMap.set(a.category,(catMap.get(a.category)||0)+1));
const cats = Array.from(catMap.entries()).sort((a,b)=>b[1]-a[1]);

const nicheColors: Record<string,string> = {'crypto-investing':'from-blue-600 to-blue-700','ai-tools':'from-violet-600 to-violet-700','bitcoin-beginners':'from-amber-500 to-orange-600','crypto-trading':'from-emerald-600 to-emerald-700','defi-yield':'from-cyan-600 to-teal-700','personal-finance':'from-green-600 to-green-700','emergency-fund':'from-rose-600 to-rose-700','budget-travel':'from-sky-600 to-indigo-600','memecoin-trading':'from-orange-500 to-amber-600'};
const nicheHeroImages: Record<string,string> = {
  'crypto-investing':'https://www.guidestack.wiki/images/heroes/crypto-investing-hero.png',
  'crypto-trading':'https://www.guidestack.wiki/images/heroes/crypto-trading-hero.png',
  'ai-tools':'https://www.guidestack.wiki/images/heroes/ai-tools-hero.png',
  'defi-yield':'https://www.guidestack.wiki/images/heroes/defi-yield-hero.png',
  'bitcoin-beginners':'https://www.guidestack.wiki/images/heroes/bitcoin-beginners-hero.png',
  'personal-finance':'https://www.guidestack.wiki/images/heroes/personal-finance-hero.png',
  'emergency-fund':'https://www.guidestack.wiki/images/heroes/emergency-fund-hero.png',
  'budget-travel':'https://www.guidestack.wiki/images/heroes/budget-travel-hero.png',
  'memecoin-trading':'https://www.guidestack.wiki/images/heroes/memecoin-trading-hero.png',
};
const gradient = nicheColors[nicheId] || 'from-slate-600 to-slate-700';
const heroImg = nicheHeroImages[nicheId];
---
<BaseLayout title={`${nc?.name||nicheId} - ${siteConfig.name}`} description={nc?.description||''} breadcrumbs={[{name:'Home',url:'/'},{name:nc?.name||nicheId,url:`/${nicheId}`}]} siteName={siteConfig.name}>
  <!-- Hero banner -->
  <div class={heroImg ? '-mx-4 sm:-mx-6 lg:-mx-8 -mt-8 sm:-mt-12 mb-10 px-4 sm:px-6 lg:px-8 py-10 text-white' : `-mx-4 sm:-mx-6 lg:-mx-8 -mt-8 sm:-mt-12 mb-10 px-4 sm:px-6 lg:px-8 py-10 bg-gradient-to-br ${gradient} text-white`} style={heroImg ? 'background: linear-gradient(to bottom, rgba(0,0,0,0.4), rgba(0,0,0,0.7)), url(' + heroImg + ') center/cover no-repeat;' : undefined}>
    <div class="max-w-7xl mx-auto">
      <nav class="mb-4">
        <ol class="flex gap-1.5 text-sm text-white/60">
          <li><a href="/" class="hover:text-white/90 transition-colors">Home</a></li>
          <li><svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></li>
          <li class="text-white font-medium">{nc?.name||nicheId}</li>
        </ol>
      </nav>
      <h1 class="text-3xl sm:text-4xl font-black tracking-tight mb-2">{nc?.name||nicheId}</h1>
      <p class="text-lg text-white/70 mb-5">{nc?.description||''}</p>
      <div class="flex gap-4 text-sm text-white/60">
        <span class="flex items-center gap-1.5"><strong class="text-white">{articles.length}</strong> Articles</span>
        <span class="flex items-center gap-1.5"><strong class="text-white">{cats.length}</strong> Categories</span>
      </div>
    </div>
  </div>

  <!-- Categories -->
  {cats.length > 1 && <section class="mb-10">
    <h2 class="text-lg font-bold text-slate-900 dark:text-white mb-4">Categories</h2>
    <div class="flex flex-wrap gap-2">
      {cats.map(([cat,count])=><a href={`/category/${cat}?niche=${nicheId}`} class="inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-slate-600 dark:text-slate-300 bg-slate-100 dark:bg-slate-800 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/30 hover:text-blue-700 dark:hover:text-blue-400 transition-colors">
        <svg class="w-3.5 h-3.5 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h6v6H4zM14 4h6v6h-6z"/></svg>
        {cat.replace(/-/g,' ')}
        <span class="text-xs text-slate-400">{count}</span>
      </a>)}
    </div>
  </section>}

  <!-- Articles -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
    {articles.map(a=><a href={`/${a.niche}/${a.slug}`} class="card group">
      <div class={`h-28 bg-gradient-to-br ${gradient} flex items-center justify-center relative`}>
        <span class="absolute top-3 right-3 text-xs font-semibold text-white/80 bg-white/15 backdrop-blur-sm px-2.5 py-1 rounded-full">{a.category.replace(/-/g,' ')}</span>
      </div>
      <div class="p-5">
        <h2 class="font-bold text-slate-900 dark:text-white mb-2 group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors line-clamp-2">{a.title}</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2 mb-3">{a.description}</p>
        <div class="flex items-center gap-2 text-xs text-slate-400">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          <span>{new Date(a.date+'T00:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</span>
          {a.readingTime && <><span class="text-slate-300 dark:text-slate-600">·</span><span>{a.readingTime} read</span></>}
        </div>
      </div>
    </a>)}
  </div>
</BaseLayout>
