---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'path';
import { marked } from 'marked';

const siteConfig = JSON.parse(fs.readFileSync('site-config.json','utf-8'));
const niches = siteConfig.niches || [];
const ARTICLES_DIR = 'src/content/articles';

// Pen names for E-E-A-T author credibility
const authorPenNames: Record<string, {name:string, bio:string, initials:string}> = {
  'Sarah Mitchell': {name:'Sarah Mitchell', bio:'Financial analyst with 12 years of experience in personal finance and cryptocurrency investing.', initials:'SM'},
  'Marcus Chen': {name:'Marcus Chen', bio:'Senior crypto trading strategist and blockchain educator. Former Wall Street analyst.', initials:'MC'},
  'Lena Patel': {name:'Lena Patel', bio:'AI researcher and productivity specialist. Covers emerging AI tools and their practical applications.', initials:'LP'},
  'Daniel Park': {name:'Daniel Park', bio:'DeFi protocol analyst and yield farming strategist. Early blockchain ecosystem contributor.', initials:'DP'},
};
const penNameKeys = Object.keys(authorPenNames);
const penName = penNameKeys[Math.floor(Math.random() * penNameKeys.length)];
const authorData = authorPenNames[penName];

function slugify(f:string) { return f.replace(/\.md$/,'').replace(/^([^-]+-){2}\d{4}-\d{2}-\d{2}-(ai-)?/,''); }
function parse(file:string) {
  const raw = fs.readFileSync(path.join(ARTICLES_DIR,file),'utf-8');
  const m = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
  if (!m) return null;
  const fm: Record<string,any> = {};
  m[1].split('\n').forEach((l:string)=>{const x=l.match(/^(\w+):\s*["']?(.+?)["']?\s*$/);if(x)fm[x[1]]=x[2]});
  if(typeof fm.tags==='string')fm.tags=fm.tags.split(',').map((t:string)=>t.trim());
  return {title:fm.title||'',description:fm.description||'',date:fm.date||'',category:fm.category||'general',tags:fm.tags||[],readingTime:fm.readingTime||'',niche:fm.niche||'general',content:marked.parse(m[2],{gfm:true,breaks:true}) as string,rawBody:m[2]};
}

export function getStaticPaths() {
  const dir = 'src/content/articles';
  const paths: any[] = [];
  if (!fs.existsSync(dir)) return paths;
  const files = fs.readdirSync(dir).filter((x:string)=>x.endsWith('.md'));
  const _slugify = (f:string) => f.replace(/\.md$/,'').replace(/^([^-]+-){2}\d{4}-\d{2}-\d{2}-(ai-)?/,'');
  for (const f of files) {
    const c = fs.readFileSync(path.join(dir,f),'utf-8');
    const nm = c.match(/^niche:\s*["']?(.+?)["']?\s*$/m);
    const sl = _slugify(f);
    paths.push({params:{niche:nm?.[1]||'general',slug:sl},props:{file:f}});
  }
  return paths;
}

const { file } = Astro.props;
const { niche, slug: s } = Astro.params;
const article = parse(file);
if (!article) return Astro.redirect('/');

const nc = niches.find((n:any)=>n.id===article.niche);
const wc = (article.rawBody||'').split(/\s+/).filter(Boolean).length;
const today = new Date().toISOString().split('T')[0];

// E-E-A-T: Person schema instead of Organization
const personSchema = {
  "@context":"https://schema.org",
  "@type":"Person",
  "name": authorData.name,
  "description": authorData.bio,
  "url": "https://guidestack.wiki",
  "image": "https://guidestack.wiki/favicon.svg",
  "sameAs": []
};
const schema = {
  "@context":"https://schema.org",
  "@type":"BlogPosting",
  "headline":article.title,
  "description":article.description,
  "datePublished":article.date,
  "dateModified":today,
  "author": personSchema,
  "publisher":{
    "@type":"Organization",
    "name":siteConfig.name,
    "logo":{"@type":"ImageObject","url":"https://guidestack.wiki/favicon.svg"}
  },
  "wordCount":wc,
  "articleSection":article.category,
  "mainEntityOfPage":{"@type":"WebPage","@id":`https://guidestack.wiki/${article.niche}/${s}`}
};
const breadcrumbs = [{name:'Home',url:'/'},{name:nc?.name||article.niche,url:`/${article.niche}`},{name:article.title,url:`/${article.niche}/${s}`}];

const allRelated: any[] = [];
if (fs.existsSync(ARTICLES_DIR)) {
  for (const f of fs.readdirSync(ARTICLES_DIR).filter((x:string)=>x.endsWith('.md'))) {
    if (f !== file) {
      const c2=fs.readFileSync(path.join(ARTICLES_DIR,f),'utf-8');
      const nm2=c2.match(/^niche:\s*["']?(.+?)["']?\s*$/m);
      const sl2=slugify(f);
      const cm=c2.match(/category:\s*["'](.+?)["']/);
      const tm=c2.match(/title:\s*["'](.+?)["']/);
      const dm=c2.match(/description:\s*["'](.+?)["']/);
      const dm2=c2.match(/date:\s*["']?(\d{4}-\d{2}-\d{2})["']?/);
      allRelated.push({title:tm?.[1]||'',slug:sl2,niche:nm2?.[1]||'general',category:cm?.[1]||'general',description:dm?.[1]||'',date:dm2?.[1]||''});
    }
  }
}
// Sort related by date, newest first
allRelated.sort((a,b)=>b.date.localeCompare(a.date));
const sameNiche = allRelated.filter(r=>r.niche===article.niche);
const related = [...sameNiche.filter(r=>r.category===article.category&&r.slug!==s).slice(0,3),...sameNiche.filter(r=>r.slug!==s).slice(0,2)].slice(0,5);

// Prev/next within same niche
const nicheArticles = allRelated.filter(r=>r.niche===article.niche);
const currIdx = nicheArticles.findIndex(r=>r.slug===s);
const prevArt = currIdx < nicheArticles.length-1 ? nicheArticles[currIdx+1] : null;
const nextArt = currIdx > 0 ? nicheArticles[currIdx-1] : null;

const headRE = /<h([2-3]) id="([^"]*)"[^>]*>(.*?)<\/h\1>/g;
const toc: any[] = []; let hm; while((hm=headRE.exec(article.content as string))!==null) toc.push({level:+hm[1],id:hm[2],text:hm[3].replace(/<[^>]*>/g,'')});
const catLabel = article.category.replace(/-/g,' ').replace(/\b\w/g,(l:string)=>l.toUpperCase());
const readMin = Math.max(1,Math.ceil(wc/200));
const canonicalUrl = `https://guidestack.wiki/${article.niche}/${s}`;
---
<BaseLayout title={`${article.title} - ${siteConfig.name}`} description={article.description} ogType="article" publishedTime={article.date} modifiedTime={today} schema={schema} breadcrumbs={breadcrumbs} siteName={siteConfig.name}>
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
    <article class="lg:col-span-8 max-w-none">
      <!-- Breadcrumbs -->
      <nav class="mb-6 flex items-center gap-1.5 text-sm text-slate-400" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5" itemscope itemtype="https://schema.org/BreadcrumbList">
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href="/" class="hover:text-blue-700 dark:hover:text-blue-400 transition-colors" itemprop="item"><span itemprop="name">Home</span></a>
            <meta itemprop="position" content="1">
          </li>
          <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href={`/${article.niche}`} class="hover:text-blue-700 dark:hover:text-blue-400 transition-colors" itemprop="item"><span itemprop="name">{nc?.name||article.niche}</span></a>
            <meta itemprop="position" content="2">
          </li>
          <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
            <span class="text-slate-600 dark:text-slate-300 font-medium truncate max-w-[200px]" itemprop="name">{article.title}</span>
            <meta itemprop="position" content="3">
          </li>
        </ol>
      </nav>

      <!-- Header -->
      <header class="mb-10">
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="badge-blue">{catLabel}</span>
          <span class="badge-slate">{nc?.name||article.niche}</span>
          {article.tags.slice(0,3).map((tag: string) => <span class="badge-slate">{tag}</span>)}
        </div>
        <h1 class="text-3xl sm:text-4xl font-black text-slate-900 dark:text-white leading-tight tracking-tight mb-5">{article.title}</h1>
        <p class="text-lg text-slate-500 dark:text-slate-400 leading-relaxed mb-6">{article.description}</p>
        <div class="flex flex-wrap items-center gap-3 text-sm text-slate-400 border-b border-slate-200 dark:border-slate-700 pb-4">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-600 to-violet-600 flex items-center justify-center text-white text-xs font-bold" aria-hidden="true">
              {authorData.initials}
            </div>
            <span class="font-medium text-slate-600 dark:text-slate-300">{authorData.name}</span>
          </div>
          <span class="text-slate-300 dark:text-slate-600 hidden sm:inline">|</span>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            <time datetime={article.date}>{article.date ? new Date(article.date+'T00:00:00').toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) : ''}</time>
          </div>
          <span class="text-slate-300 dark:text-slate-600 hidden sm:inline">|</span>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>{readMin} min read</span>
          </div>
        </div>
      </header>

      <!-- Content -->
      <div class="prose prose-lg max-w-none" set:html={article.content} />

      <!-- Share Buttons -->
      <section class="mt-10 pt-6 border-t border-slate-200 dark:border-slate-700" aria-label="Share this article">
        <div class="flex flex-wrap items-center gap-3">
          <span class="text-sm font-semibold text-slate-600 dark:text-slate-300">Share:</span>
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(canonicalUrl)}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg text-sm font-medium transition-colors" aria-label="Share on X (Twitter)">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Post
          </a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonicalUrl)}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg text-sm font-medium transition-colors" aria-label="Share on Facebook">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </a>
          <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(canonicalUrl)}&title=${encodeURIComponent(article.title)}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg text-sm font-medium transition-colors" aria-label="Share on LinkedIn">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <button onclick={`navigator.clipboard.writeText('${canonicalUrl}').then(()=>{this.textContent='Copied!';setTimeout(()=>this.textContent='Copy Link',2000)})`} class="flex items-center gap-2 px-4 py-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 rounded-lg text-sm font-medium transition-colors cursor-pointer" aria-label="Copy link to clipboard">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            Copy Link
          </button>
        </div>
      </section>

      <!-- Author Bio Box -->
      <section class="mt-8 p-6 bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 rounded-xl" aria-label="About the author">
        <div class="flex items-start gap-4">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-blue-600 to-violet-600 flex items-center justify-center text-white text-lg font-bold shrink-0" aria-hidden="true">
            {authorData.initials}
          </div>
          <div>
            <p class="text-xs font-semibold text-blue-700 dark:text-blue-400 uppercase tracking-wider mb-1">Written by</p>
            <h3 class="font-bold text-slate-900 dark:text-white mb-1">{authorData.name}</h3>
            <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">{authorData.bio}</p>
          </div>
        </div>
      </section>

      <!-- Prev / Next Navigation -->
      {(prevArt || nextArt) && <nav class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4" aria-label="Article navigation">
        {prevArt ? <a href={`/${prevArt.niche}/${prevArt.slug}`} class="card group p-4 text-left">
          <span class="text-xs text-slate-400 mb-1 block">← Previous</span>
          <span class="font-semibold text-sm text-slate-700 dark:text-slate-200 group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors line-clamp-2">{prevArt.title}</span>
        </a> : <div></div>}
        {nextArt ? <a href={`/${nextArt.niche}/${nextArt.slug}`} class="card group p-4 text-right">
          <span class="text-xs text-slate-400 mb-1 block">Next →</span>
          <span class="font-semibold text-sm text-slate-700 dark:text-slate-200 group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors line-clamp-2">{nextArt.title}</span>
        </a> : <div></div>}
      </nav>}

      <!-- Related -->
      {related.length > 0 && <section class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-700">
        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Continue Reading
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {related.map(r=><a href={`/${r.niche}/${r.slug}`} class="card group p-4">
            <span class="badge-blue text-xs mb-2 inline-block">{r.category.replace(/-/g,' ')}</span>
            <h4 class="font-semibold text-sm text-slate-900 dark:text-white group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors line-clamp-2">{r.title}</h4>
            <p class="text-xs text-slate-400 mt-2 line-clamp-2">{r.description}</p>
          </a>)}
        </div>
      </section>}
    </article>

    <!-- Sidebar -->
    <aside class="lg:col-span-4">
      <div class="sticky top-24 space-y-6">
        {toc.length > 0 && <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl p-5">
          <h3 class="font-semibold text-sm text-slate-900 dark:text-white mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/><line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/></svg>
            On This Page
          </h3>
          <nav class="space-y-0.5" aria-label="Table of contents">{toc.map(item=><a href={`#${item.id}`} class={`toc-link ${item.level===3?'pl-6':''}`}>{item.text}</a>)}</nav>
        </div>}

        <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl p-5">
          <h3 class="font-semibold text-sm text-slate-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            Trending Guides
          </h3>
          <ul class="space-y-3">{allRelated.slice(0,6).map((p,i)=><li class="flex gap-3">
            <span class="shrink-0 w-6 h-6 rounded-lg bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-xs font-bold text-blue-700 dark:text-blue-400" aria-hidden="true">{i+1}</span>
            <a href={`/${p.niche}/${p.slug}`} class="text-sm text-slate-600 dark:text-slate-300 hover:text-blue-700 dark:hover:text-blue-400 line-clamp-2 transition-colors">{p.title}</a>
          </li>)}</ul>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>