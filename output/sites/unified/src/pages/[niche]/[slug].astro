---
import BaseLayout from '../../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';
import { marked } from 'marked';

const siteConfig = JSON.parse(fs.readFileSync('site-config.json','utf-8'));
const niches = siteConfig.niches || [];
const ARTICLES_DIR = 'src/content/articles';

function slugify(f:string) { return f.replace(/\.md$/,'').replace(/^([^-]+-){2}\d{4}-\d{2}-\d{2}-(ai-)?/,''); }
function parse(file:string) {
  const raw = fs.readFileSync(path.join(ARTICLES_DIR,file),'utf-8');
  const m = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
  if (!m) return null;
  const fm: Record<string,any> = {};
  m[1].split('\n').forEach((l:string)=>{const x=l.match(/^(\w+):\s*["']?(.+?)["']?\s*$/);if(x)fm[x[1]]=x[2]});
  if(typeof fm.tags==='string')fm.tags=fm.tags.split(',').map((t:string)=>t.trim());
  return {title:fm.title||'',description:fm.description||'',date:fm.date||'',category:fm.category||'general',tags:fm.tags||[],readingTime:fm.readingTime||'',niche:fm.niche||'general',content:marked.parse(m[2],{gfm:true,breaks:true}) as string,rawBody:m[2]};
}

export function getStaticPaths() {
  const dir = 'src/content/articles';
  const paths: any[] = [];
  if (!fs.existsSync(dir)) return paths;
  for (const f of fs.readdirSync(dir).filter((x:string)=>x.endsWith('.md'))) {
    const c = fs.readFileSync(path.join(dir,f),'utf-8');
    const nm = c.match(/^niche:\s*["']?(.+?)["']?\s*$/m);
    const sl = f.replace(/\.md$/,'').replace(/^([^-]+-){2}\d{4}-\d{2}-\d{2}-(ai-)?/,'');
    // Prefix slug with niche to avoid collisions across niches
    const nicheSlug = sl;  // Niche is already in URL path, not in slug
    paths.push({params:{niche:nm?.[1]||'general',slug:nicheSlug},props:{file:f}});
  }
  return paths;
}

const { file } = Astro.props;
const { niche, slug: s } = Astro.params;
const article = parse(file);
if (!article) return Astro.redirect('/');

const nc = niches.find((n:any)=>n.id===article.niche);
const wc = (article.rawBody||'').split(/\s+/).filter(Boolean).length;
const today = new Date().toISOString().split('T')[0];
const schema = {"@context":"https://schema.org","@type":"BlogPosting","headline":article.title,"description":article.description,"datePublished":article.date,"dateModified":today,"author":{"@type":"Organization","name":siteConfig.author||siteConfig.name},"publisher":{"@type":"Organization","name":siteConfig.name},"wordCount":wc,"articleSection":article.category};
const breadcrumbs = [{name:'Home',url:'/'},{name:nc?.name||article.niche,url:`/${article.niche}`},{name:article.title,url:`/${article.niche}/${s}`}];

const allRelated: any[] = [];
if (fs.existsSync(ARTICLES_DIR)) { for (const f of fs.readdirSync(ARTICLES_DIR).filter((x:string)=>x.endsWith('.md'))) { if (f !== file) { const c2=fs.readFileSync(path.join(ARTICLES_DIR,f),'utf-8'); const nm2=c2.match(/^niche:\s*["']?(.+?)["']?\s*$/m); const sl2=f.replace(/\.md$/,'').replace(/^([^-]+-){2}\d{4}-\d{2}-\d{2}-(ai-)?/,''); const nicheSlug=sl2; const cm=c2.match(/category:\s*["'](.+?)["']/); const tm=c2.match(/title:\s*["'](.+?)["']/); const dm=c2.match(/description:\s*["'](.+?)["']/); allRelated.push({title:tm?.[1]||'',slug:nicheSlug,niche:nm2?.[1]||'general',category:cm?.[1]||'general',description:dm?.[1]||''}); }}}
const related = [...allRelated.filter(r=>r.category===article.category&&r.niche===article.niche).slice(0,3),...allRelated.filter(r=>r.niche===article.niche).slice(0,2)].slice(0,5);

const headRE = /<h([2-3]) id="([^"]*)"[^>]*>(.*?)<\/h\1>/g;
const toc: any[] = []; let hm; while((hm=headRE.exec(article.content as string))!==null) toc.push({level:+hm[1],id:hm[2],text:hm[3].replace(/<[^>]*>/g,'')});
const catLabel = article.category.replace(/-/g,' ').replace(/\b\w/g,(l:string)=>l.toUpperCase());
const readMin = Math.max(1,Math.ceil(wc/200));
---
<BaseLayout title={`${article.title} - ${siteConfig.name}`} description={article.description} ogType="article" publishedTime={article.date} modifiedTime={today} schema={schema} breadcrumbs={breadcrumbs} siteName={siteConfig.name}>
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
    <article class="lg:col-span-8 max-w-none">
      <!-- Breadcrumbs -->
      <nav class="mb-6 flex items-center gap-1.5 text-sm text-slate-400">
        <a href="/" class="hover:text-blue-700 dark:hover:text-blue-400 transition-colors">Home</a>
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <a href={`/${article.niche}`} class="hover:text-blue-700 dark:hover:text-blue-400 transition-colors">{nc?.name||article.niche}</a>
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-slate-600 dark:text-slate-300 font-medium truncate max-w-[200px]">{article.title}</span>
      </nav>

      <!-- Header -->
      <header class="mb-10">
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="badge-blue">{catLabel}</span>
          <span class="badge-slate">{nc?.name||article.niche}</span>
          {article.tags.slice(0,3).map((tag: string) => <span class="badge-slate">{tag}</span>)}
        </div>
        <h1 class="text-3xl sm:text-4xl font-black text-slate-900 dark:text-white leading-tight tracking-tight mb-5">{article.title}</h1>
        <p class="text-lg text-slate-500 dark:text-slate-400 leading-relaxed mb-6">{article.description}</p>
        <div class="flex items-center gap-3 text-sm text-slate-400 border-b border-slate-200 dark:border-slate-700 pb-4">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-600 to-violet-600 flex items-center justify-center text-white text-xs font-bold">
              {(siteConfig.author||'PP').split(' ').map((w:string)=>w[0]).join('').substring(0,2)}
            </div>
            <span class="font-medium text-slate-600 dark:text-slate-300">{siteConfig.author}</span>
          </div>
          <span class="text-slate-300 dark:text-slate-600">|</span>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            <span>{article.date ? new Date(article.date+'T00:00:00').toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) : ''}</span>
          </div>
          <span class="text-slate-300 dark:text-slate-600">|</span>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>{readMin} min read</span>
          </div>
        </div>
      </header>

      <!-- Content -->
      <div class="prose prose-lg max-w-none" set:html={article.content} />

      <!-- Related -->
      {related.length > 0 && <section class="mt-12 pt-8 border-t border-slate-200 dark:border-slate-700">
        <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          Continue Reading
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {related.map(r=><a href={`/${r.niche}/${r.slug}`} class="card group p-4">
            <span class="badge-blue text-xs mb-2">{r.category.replace(/-/g,' ')}</span>
            <h4 class="font-semibold text-sm text-slate-900 dark:text-white group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors line-clamp-2">{r.title}</h4>
            <p class="text-xs text-slate-400 mt-2 line-clamp-2">{r.description}</p>
          </a>)}
        </div>
      </section>}
    </article>

    <!-- Sidebar -->
    <aside class="lg:col-span-4">
      <div class="sticky top-24 space-y-6">
        {toc.length > 0 && <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl p-5">
          <h3 class="font-semibold text-sm text-slate-900 dark:text-white mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/><line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/></svg>
            On This Page
          </h3>
          <nav class="space-y-0.5">{toc.map(item=><a href={`#${item.id}`} class={`toc-link ${item.level===3?'pl-6':''}`}>{item.text}</a>)}</nav>
        </div>}

        <div class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl p-5">
          <h3 class="font-semibold text-sm text-slate-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-amber-500" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            Trending
          </h3>
          <ul class="space-y-3">{allRelated.slice(0,6).map((p,i)=><li class="flex gap-3">
            <span class="shrink-0 w-6 h-6 rounded-lg bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-xs font-bold text-blue-700 dark:text-blue-400">{i+1}</span>
            <a href={`/${p.niche}/${p.slug}`} class="text-sm text-slate-600 dark:text-slate-300 hover:text-blue-700 dark:hover:text-blue-400 line-clamp-2 transition-colors">{p.title}</a>
          </li>)}</ul>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>
