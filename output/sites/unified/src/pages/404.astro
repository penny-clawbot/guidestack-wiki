---
import BaseLayout from '../layouts/BaseLayout.astro';
const siteConfig = JSON.parse(fs.readFileSync('site-config.json','utf-8'));
---
<BaseLayout title={`Page Not Found - ${siteConfig.name}`} description="The page you're looking for doesn't exist.">
  <div class="min-h-[60vh] flex items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <div class="text-8xl font-black text-slate-200 dark:text-slate-700 mb-4">404</div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Page Not Found</h1>
      <p class="text-slate-500 dark:text-slate-400 mb-8">The page you're looking for has moved, been deleted, or never existed. Try searching for what you need.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/" class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors">Go Home</a>
        <a href="/ai-tools" class="px-6 py-3 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-200 font-semibold rounded-lg transition-colors">Browse Guides</a>
      </div>
      <div class="mt-12">
        <p class="text-xs text-slate-400 mb-3">Popular guides:</p>
        <ul class="text-sm text-slate-500 space-y-1">
          <li><a href="/crypto-investing/how-to-read-crypto-charts-for-beginners" class="hover:text-blue-700 dark:hover:text-blue-400 transition-colors">How to Read Crypto Charts for Beginners</a></li>
          <li><a href="/bitcoin-beginners/how-to-create-a-bitcoin-wallet" class="hover:text-blue-700 dark:hover:text-blue-400 transition-colors">How to Create a Bitcoin Wallet</a></li>
          <li><a href="/personal-finance/emergency-fund-vs-credit-line" class="hover:text-blue-700 dark:hover:text-blue-400 transition-colors">Emergency Fund vs Credit Line</a></li>
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>