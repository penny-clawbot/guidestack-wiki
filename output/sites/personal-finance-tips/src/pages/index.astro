---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const contentDir = 'src/content/articles';

interface Article { title: string; description: string; slug: string; date: string; category: string; readingTime: string; tags: string[]; }
const articles: Article[] = [];

if (fs.existsSync(contentDir)) {
  for (const file of fs.readdirSync(contentDir).filter(f => f.endsWith('.md'))) {
    const content = fs.readFileSync(path.join(contentDir, file), 'utf-8');
    const fm: Record<string, any> = {};
    const fmMatch = content.match(/^---\n([\s\S]*?)\n---/);
    if (fmMatch) {
      fmMatch[1].split('\n').forEach(line => {
        const m = line.match(/^(\w+):\s*["']?(.+?)["']?\s*$/);
        if (m) fm[m[1]] = m[2];
      });
      if (typeof fm.tags === 'string') fm.tags = fm.tags.split(',').map((t: string) => t.trim());
      articles.push({
        title: fm.title || file, description: fm.description || '',
        slug: file.replace(/\.md$/, '').replace(/^\d{4}-\d{2}-\d{2}-(ai-)?/, ''),
        date: fm.date || '', category: fm.category || 'general',
        readingTime: fm.readingTime || '', tags: fm.tags || [],
      });
    }
  }
}

articles.sort((a, b) => b.date.localeCompare(a.date));
const siteConfig = JSON.parse(fs.readFileSync('site-config.json', 'utf-8'));
const featured = articles.slice(0, 3);
const recent = articles.slice(3, 12);
const totalArticles = articles.length;
const totalWords = articles.reduce((sum, a) => sum + (parseInt(a.readingTime) || 5) * 200, 0);
const categories = [...new Set(articles.map(a => a.category))];
---

<BaseLayout title={siteConfig.name} description={siteConfig.description} ogType="website" siteName={siteConfig.name}>
  <!-- Hero -->
  <section class="mb-12 py-8">
    <div class="max-w-3xl">
      <div class="badge-primary mb-4">✈️ Your Travel Resource</div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-[var(--color-text-heading)] mb-5 leading-tight">
        {siteConfig.name}
      </h1>
      <p class="text-lg sm:text-xl text-[var(--color-text-muted)] leading-relaxed mb-6">
        {siteConfig.description}
      </p>
      <div class="flex flex-wrap gap-3 text-sm text-[var(--color-text-muted)]">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
          {totalArticles} Articles
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {(totalWords / 1000).toFixed(0)}K+ Words
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
          {categories.length} Categories
        </span>
      </div>
    </div>
  </section>

  <!-- Featured Articles -->
  {featured.length > 0 && (
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-[var(--color-text-heading)] mb-6 flex items-center gap-2">
        <span class="text-[var(--color-accent)]">⭐</span> Featured
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {featured.map((a, i) => (
          <a href={`/${a.slug}`} class={`card group ${i === 0 ? 'md:col-span-1' : ''}`}>
            <div class="h-48 bg-gradient-to-br from-[var(--color-primary)]/10 to-[var(--color-accent)]/10 flex items-center justify-center">
              <span class="text-5xl opacity-60">{i === 0 ? '✈️' : i === 1 ? '🗺️' : '💡'}</span>
            </div>
            <div class="p-5">
              <div class="badge-primary mb-3 text-xs">{a.category.replace(/-/g, ' ')}</div>
              <h3 class="font-bold text-[var(--color-text-heading)] mb-2 group-hover:text-[var(--color-primary)] transition-colors line-clamp-2">{a.title}</h3>
              <p class="text-sm text-[var(--color-text-muted)] line-clamp-2">{a.description}</p>
              <div class="mt-3 flex items-center gap-3 text-xs text-[var(--color-text-muted)]">
                <span>{new Date(a.date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                {a.readingTime && <span>{a.readingTime} read</span>}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Recent Articles -->
  <section class="mb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-[var(--color-text-heading)]">Latest Articles</h2>
      <span class="text-sm text-[var(--color-text-muted)]">{articles.length} total</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {recent.map(a => (
        <a href={`/${a.slug}`} class="card group">
          <div class="p-5">
            <div class="badge-primary mb-3 text-xs">{a.category.replace(/-/g, ' ')}</div>
            <h3 class="font-bold text-[var(--color-text-heading)] mb-2 group-hover:text-[var(--color-primary)] transition-colors line-clamp-2">{a.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] line-clamp-3 mb-3">{a.description}</p>
            <div class="flex items-center gap-3 text-xs text-[var(--color-text-muted)]">
              <span>{new Date(a.date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              {a.readingTime && <span>· {a.readingTime} read</span>}
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Load more / All articles link -->
  {articles.length > 12 && (
    <div class="text-center mb-12">
      <a href="/all-articles" class="btn-secondary">View All {articles.length} Articles →</a>
    </div>
  )}

  <!-- Categories -->
  {categories.length > 1 && (
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-[var(--color-text-heading)] mb-6">Browse by Category</h2>
      <div class="flex flex-wrap gap-3">
        {categories.map(cat => (
          <a href={`/category/${cat}`} class="badge bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] hover:bg-[var(--color-primary-light)] hover:text-[var(--color-primary)] transition-all px-4 py-2 text-sm font-medium">
            {cat.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Ad slot -->
  <div class="ad-slot my-8">
    <span>Advertisement</span>
  </div>
</BaseLayout>
