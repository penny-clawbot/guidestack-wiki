---
export interface Crumb {
  name: string;
  url: string;
}

export interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex items-center flex-wrap gap-2 text-sm">
    {crumbs.map((crumb, idx) => (
      <li class="flex items-center">
        {idx > 0 && (
          <span class="mx-2 text-[var(--color-text-muted)]">/</span>
        )}
        {idx === crumbs.length - 1 ? (
          <span class="text-[var(--color-text-muted)]" aria-current="page">{crumb.name}</span>
        ) : (
          <a href={crumb.url} class="text-primary hover:underline">{crumb.name}</a>
        )}
      </li>
    ))}
  </ol>
</nav>
