---
export interface Props {
  title: string;
  description?: string;
  slug: string;
  image?: string;
  publishedAt?: string;
  categories?: string[];
  readingTime?: number;
}

const {
  title,
  description = '',
  slug,
  image,
  publishedAt,
  categories = [],
  readingTime
} = Astro.props;

const formattedDate = publishedAt ? new Date(publishedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
}) : '';
---

<article class="bg-[var(--color-bg)] border border-[var(--color-border)] rounded-xl overflow-hidden hover:shadow-lg transition-shadow">
  {image && (
    <a href={`/${slug}`} class="block">
      <img src={image} alt={title} class="w-full h-48 object-cover" loading="lazy" />
    </a>
  )}

  <div class="p-5">
    <!-- Categories -->
    {categories.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-3">
        {categories.map(cat => (
          <a href={`/category/${cat.toLowerCase().replace(/\s+/g, '-')}`}
             class="text-xs font-medium px-2 py-1 bg-primary/10 text-primary rounded-full hover:bg-primary/20">
            {cat}
          </a>
        ))}
      </div>
    )}

    <!-- Title -->
    <h2 class="text-lg font-semibold mb-2 line-clamp-2">
      <a href={`/${slug}`} class="hover:text-primary transition-colors">
        {title}
      </a>
    </h2>

    <!-- Description -->
    {description && (
      <p class="text-sm text-[var(--color-text-muted)] mb-3 line-clamp-3">{description}</p>
    )}

    <!-- Meta -->
    <div class="flex items-center gap-3 text-xs text-[var(--color-text-muted)]">
      {formattedDate && <span>{formattedDate}</span>}
      {readingTime && <span>{readingTime} min read</span>}
    </div>
  </div>
</article>
