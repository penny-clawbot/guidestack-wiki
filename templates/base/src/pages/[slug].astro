---
import BaseLayout from '../layouts/BaseLayout.astro';
import CrossSiteLinks from '../components/CrossSiteLinks.astro';
import MidArticleCTA from '../components/MidArticleCTA.astro';
import fs from 'node:fs';
import path from 'node:path';
import { marked, resetHeadingCounter } from '../utils/marked-config';

const cd = 'src/content/articles';

function parseFile(file: string) {
  const raw = fs.readFileSync(path.join(cd, file), 'utf-8');
  const fmMatch = raw.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
  if (!fmMatch) return null;
  const fm: Record<string, any> = {};
  fmMatch[1].split('\n').forEach((line: string) => {
    const m = line.match(/^(\w+):\s*["']?(.+?)["']?\s*$/);
    if (m) fm[m[1]] = m[2];
  });
  if (typeof fm.tags === 'string') fm.tags = fm.tags.split(',').map((t: string) => t.trim());
  resetHeadingCounter();
  const htmlContent = marked.parse(fmMatch[2]) as string;
  return { title: fm.title || '', description: fm.description || '', date: fm.date || '', category: fm.category || 'general', tags: fm.tags || [], content: htmlContent, readingTime: fm.readingTime || '', rawBody: fmMatch[2] };
}

export function getStaticPaths() {
  const cd2 = 'src/content/articles';
  const slugs: string[] = [];
  if (fs.existsSync(cd2)) {
    for (const file of fs.readdirSync(cd2).filter((f: string) => f.endsWith('.md'))) {
      slugs.push(file.replace(/\.md$/, '').replace(/^\d{4}-\d{2}-\d{2}-(ai-)?/, ''));
    }
  }
  return slugs.map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
let article: any = null;
let articleFile = '';

if (fs.existsSync(cd)) {
  for (const file of fs.readdirSync(cd).filter((f: string) => f.endsWith('.md'))) {
    if (file.replace(/\.md$/, '').replace(/^\d{4}-\d{2}-\d{2}-(ai-)?/, '') === slug) {
      article = parseFile(file);
      articleFile = file;
      break;
    }
  }
}
if (!article) return Astro.redirect('/');

const siteConfig = JSON.parse(fs.readFileSync('site-config.json', 'utf-8'));

// Load affiliate links
let affiliateLinks: Array<{keyword: string; url: string; title: string}> = [];
const affiliatePath = 'src/data/affiliates.json';
if (fs.existsSync(affiliatePath)) {
  try { affiliateLinks = JSON.parse(fs.readFileSync(affiliatePath, 'utf-8')).links || []; } catch {}
}

const domain = siteConfig.domain || 'example.com';
const siteUrl = `https://${domain}`;

// Get all articles for related posts
const allArticles: Array<{title: string; slug: string; category: string; description: string; readingTime: string; date: string}> = [];
if (fs.existsSync(cd)) {
  for (const file of fs.readdirSync(cd).filter((f: string) => f.endsWith('.md'))) {
    const s = file.replace(/\.md$/, '').replace(/^\d{4}-\d{2}-\d{2}-(ai-)?/, '');
    if (s !== slug) {
      const a = parseFile(file);
      if (a) allArticles.push({ title: a.title, slug: s, category: a.category, description: a.description, readingTime: a.readingTime, date: a.date });
    }
  }
}

// Related: same category first, then recent
const sameCategory = allArticles.filter(a => a.category === article.category);
const otherCategory = allArticles.filter(a => a.category !== article.category);
const related = [...sameCategory.slice(0, 4), ...otherCategory.slice(0, 4)].slice(0, 5);

const formattedDate = article.date ? new Date(article.date + 'T00:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
const catLabel = article.category.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase());
const wordCount = (article.rawBody || '').split(/\s+/).filter(Boolean).length;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: catLabel, url: `/category/${article.category}` },
  { name: article.title, url: `/${slug}` }
];

// ========== FAQ Auto-Extraction ==========
const contentStr = article.content as string;
const faqItems: Array<{question: string; answer: string}> = [];

// Match FAQ section headers
const faqSectionRegex = /<(?:h2|h3)[^>]*>(?:.*?(?:FAQ|Frequently Asked Questions|Common Questions|Questions(?:\s+&|\s+and)?\s+Answers?).*?)<\/(?:h2|h3)>([\s\S]*?)(?=<h[23][^>]*>(?!.*?(?:answer|respond|reply))<\/article|$)/i;
const faqMatch = contentStr.match(faqSectionRegex);

if (faqMatch) {
  const faqContent = faqMatch[1];
  const qaRegex = /<(?:h3|h4)[^>]*>(.*?)<\/(?:h3|h4)>\s*([\s\S]*?)(?=<(?:h3|h4)[^>]*>|$)/g;
  let qaMatch;
  while ((qaMatch = qaRegex.exec(faqContent)) !== null) {
    const q = qaMatch[1].replace(/<[^>]*>/g, '').trim();
    const a = qaMatch[2].replace(/<[^>]*>/g, '').trim().substring(0, 500);
    if (q.length > 5 && a.length > 10) {
      faqItems.push({ question: q, answer: a });
    }
  }
}

// ========== Callout Box Conversion ==========
// Convert markdown callout patterns: > [!TIP], > [!WARNING], > [!NOTE], > [!IMPORTANT]
let enhancedContent = contentStr.replace(
  /<blockquote><p>\[!(TIP|WARNING|NOTE|IMPORTANT)\]\s*(.*?)<\/p><\/blockquote>/gi,
  (_, type, text) => `<div class="callout callout-${type.toLowerCase()}"><p>${text}</p></div>`
);

// Smart internal linking: title phrases + category keywords + entity mentions
const linkableArticles = allArticles.slice(0, 20);
let linkCount = 0;
const MAX_LINKS = 5;
for (const ra of linkableArticles) {
  if (linkCount >= MAX_LINKS) break;
  const titleWords = ra.title.split(' ').filter(w => w.length > 4).slice(0, 3);
  if (titleWords.length >= 2) {
    const phrase = titleWords.join(' ');
    const escaped = phrase.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    if (enhancedContent.toLowerCase().includes(phrase.toLowerCase()) && !enhancedContent.includes(`/${ra.slug}"`)) {
      const regex = new RegExp(`(${escaped})`, 'i');
      if ((enhancedContent.match(regex) || []).length === 1) {
        enhancedContent = enhancedContent.replace(regex, `<a href="/${ra.slug}">$1</a>`);
        linkCount++; continue;
      }
    }
  }
  if (ra.category === article.category) {
    const catKeywords = ra.title.split(' ').filter(w => w.length > 5 && !['which','their','about','other','these','those','being','where','should'].includes(w.toLowerCase()));
    for (const kw of catKeywords.slice(0, 2)) {
      if (linkCount >= MAX_LINKS) break;
      const escaped = kw.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      const regex = new RegExp(`(?<![\w/])(${escaped})(?![\w"])`, 'g');
      const matches = enhancedContent.match(regex);
      if (matches && matches.length === 1 && !enhancedContent.includes(`/${ra.slug}"`)) {
        enhancedContent = enhancedContent.replace(regex, `<a href="/${ra.slug}">$1</a>`);
        linkCount++; break;
      }
    }
  }
}

// Affiliate link injection (conservative: max 3 per article)
let affCount = 0;
const MAX_AFF = 3;
for (const aff of affiliateLinks) {
  if (affCount >= MAX_AFF) break;
  const kw = aff.keyword;
  const escaped = kw.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  const regex = new RegExp(`(?<![\\w/])(${escaped})(?![\\w"](?:<|/a))`, 'i');
  if (enhancedContent.match(regex) && !enhancedContent.includes(aff.url)) {
    enhancedContent = enhancedContent.replace(regex, `<a href="${aff.url}" target="_blank" rel="noopener sponsored" title="${aff.title}">$1</a>`);
    affCount++;
  }
}

// Mid-article CTA: insert marker after 3rd H2
const CTA_MARKER = '<!--CTA_MARKER-->';
const h2Matches = [...enhancedContent.matchAll(/<h2[^>]*>/g)];
if (h2Matches.length >= 3) {
  const insertPos = h2Matches[2].index + h2Matches[2][0].length;
  const afterH2 = enhancedContent.slice(insertPos);
  const nextSection = afterH2.search(/<h[23][^>]*>/);
  const endPos = nextSection > -1 ? insertPos + nextSection : insertPos + 500;
  enhancedContent = enhancedContent.slice(0, endPos) + CTA_MARKER + enhancedContent.slice(endPos);
}
const contentParts = enhancedContent.split(CTA_MARKER);

// ========== Enhanced Article Schema ==========
const today = new Date().toISOString().split('T')[0];
const ogImageUrl = `data:image/svg+xml,${encodeURIComponent(`<svg xmlns='http://www.w3.org/2000/svg' width='1200' height='630'><defs><linearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'><stop offset='0%25' style='stop-color:%232563eb'/><stop offset='100%25' style='stop-color:%237c3aed'/></linearGradient></defs><rect width='1200' height='630' fill='url(%23g)'/><text x='600' y='280' text-anchor='middle' fill='white' font-family='system-ui,sans-serif' font-size='48' font-weight='bold'>${article.title.length > 60 ? article.title.substring(0, 57) + '...' : article.title}</text><text x='600' y='360' text-anchor='middle' fill='rgba(255,255,255,0.8)' font-family='system-ui,sans-serif' font-size='24'>${siteConfig.name}</text></svg>`)}`;

const breadcrumbsSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((crumb: any, idx: number) => ({
    "@type": "ListItem",
    "position": idx + 1,
    "name": crumb.name,
    "item": `${siteUrl}${crumb.url}`
  }))
};

const schemaObj: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": article.title,
  "description": article.description,
  "inLanguage": "en-US",
  "url": `${siteUrl}/${slug}`,
  "datePublished": article.date,
  "dateModified": today,
  "author": {
    "@type": "Organization",
    "name": siteConfig.author || siteConfig.name,
    "url": siteUrl,
    ...(siteConfig.social ? { "sameAs": Object.values(siteConfig.social) } : {})
  },
  "publisher": {
    "@type": "Organization",
    "name": siteConfig.name,
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/logo.png`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}/${slug}`
  },
  "image": ogImageUrl,
  "wordCount": wordCount,
  "articleSection": article.category,
  "keywords": article.tags && article.tags.length > 0 ? article.tags.join(", ") : undefined,
  "articleBody": (article.rawBody || '').substring(0, 500),
  "about": {
    "@type": "Thing",
    "name": catLabel,
    "description": article.description
  }
};

// Build FAQPage schema if FAQs found (separate from Article schema)
let faqSchema = null;
if (faqItems.length > 0) {
  faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.slice(0, 10).map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  };
}

const schema = schemaObj;

// Extract headings for TOC
const headingRegex = /<h([2-3]) id="([^"]*)"[^>]*>(.*?)<\/h\1>/g;
const tocItems: Array<{level: number; id: string; text: string}> = [];
let match;
while ((match = headingRegex.exec(article.content)) !== null) {
  tocItems.push({
    level: parseInt(match[1]),
    id: match[2],
    text: match[3].replace(/<[^>]*>/g, '')
  });
}
---

<BaseLayout
  title={`${article.title} - ${siteConfig.name}`}
  description={article.description}
  ogType="article"
  publishedTime={article.date}
  modifiedTime={today}
  author={siteConfig.author || siteConfig.name}
  categories={article.tags}
  articleSection={article.category}
  schema={schema}
  extraSchemas={faqSchema ? [faqSchema, breadcrumbsSchema] : [breadcrumbsSchema]}
  breadcrumbs={breadcrumbs}
  siteName={siteConfig.name}
>
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
    <!-- Main article -->
    <article class="lg:col-span-8 max-w-none">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center flex-wrap gap-1.5 text-sm text-[var(--color-text-muted)]">
          <li><a href="/" class="hover:text-[var(--color-primary)] transition-colors">Home</a></li>
          <li><span class="mx-1">›</span></li>
          <li><a href={`/category/${article.category}`} class="hover:text-[var(--color-primary)] transition-colors">{catLabel}</a></li>
          <li><span class="mx-1">›</span></li>
          <li class="text-[var(--color-text)] font-medium truncate max-w-[200px]">{article.title}</li>
        </ol>
      </nav>

      <!-- Article header -->
      <header class="mb-10">
        <div class="flex flex-wrap gap-2 mb-4">
          <span class="badge-primary">{catLabel}</span>
          {article.tags.slice(0, 3).map((tag: string) => (
            <span class="badge bg-[var(--color-bg-alt)] text-[var(--color-text-muted)]">{tag}</span>
          ))}
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-[2.75rem] font-extrabold text-[var(--color-text-heading)] leading-tight mb-5">
          {article.title}
        </h1>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed mb-5">{article.description}</p>
        <div class="flex items-center gap-4 text-sm text-[var(--color-text-muted)]">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] flex items-center justify-center text-white text-xs font-bold">
              {(siteConfig.author || siteConfig.name).split(' ').map((w: string) => w[0]).join('').substring(0, 2)}
            </div>
            <span class="font-medium text-[var(--color-text)]">{siteConfig.author || siteConfig.name}</span>
            <span class="text-xs text-[var(--color-text-muted)] hidden sm:inline">· {siteConfig.niche ? `${siteConfig.niche.charAt(0).toUpperCase() + siteConfig.niche.slice(1)} Expert` : 'Editorial Team'}</span>
          </div>
          <span>·</span>
          <span class="text-xs opacity-70">Published {formattedDate}</span>
          {article.readingTime && <><span>·</span><span>{article.readingTime} read</span></>}
          {!article.readingTime && <><span>·</span><span>{Math.max(1, Math.ceil(wordCount / 200))} min read</span></>}
          <span>·</span>
          <span class="text-xs opacity-70">Updated {new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
        </div>
      </header>

      <!-- Ad -->
      <div class="ad-slot mb-8">
        <span>Advertisement</span>
      </div>

      <!-- Article body with enhanced rendering -->
      {contentParts.length > 1 ? (
        <div>
          <div class="prose prose-lg max-w-none" set:html={contentParts[0]} />
          <MidArticleCTA niche={siteConfig.niche || catLabel} />
          <div class="prose prose-lg max-w-none" set:html={contentParts[1]} />
        </div>
      ) : (
        <div class="prose prose-lg max-w-none" set:html={enhancedContent} />
      )}

      <!-- FAQ Section (auto-extracted from content) -->
      {faqItems.length > 0 && (
        <section class="mt-12 pt-8 border-t border-[var(--color-border)]">
          <h2 class="text-2xl font-bold text-[var(--color-text-heading)] mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Frequently Asked Questions
          </h2>
          <div class="space-y-2">
            {faqItems.map(item => (
              <div class="faq-item">
                <button class="faq-question" aria-expanded="false">
                  <span>{item.question}</span>
                </button>
                <div class="faq-answer">
                  <p>{item.answer}</p>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Bottom ad -->
      <div class="ad-slot mt-10">
        <span>Advertisement</span>
      </div>

      <!-- Tags -->
      {article.tags.length > 0 && (
        <div class="mt-10 pt-8 border-t border-[var(--color-border)]">
          <h3 class="text-sm font-semibold text-[var(--color-text-heading)] mb-3">Related Topics</h3>
          <div class="flex flex-wrap gap-2">
            {article.tags.map((tag: string) => (
              <span class="badge bg-[var(--color-bg-alt)] text-[var(--color-text-muted)] hover:bg-[var(--color-primary-light)] hover:text-[var(--color-primary)] transition-all cursor-pointer">{tag}</span>
            ))}
          </div>
        </div>
      )}

      <!-- Related articles -->
      {related.length > 0 && (
        <section class="mt-12 pt-8 border-t border-[var(--color-border)]">
          <h3 class="text-xl font-bold text-[var(--color-text-heading)] mb-6">📖 Continue Reading</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {related.slice(0, 4).map(r => (
              <a href={`/${r.slug}`} class="card group p-4">
                <span class="badge-primary text-xs mb-2">{r.category.replace(/-/g, ' ')}</span>
                <h4 class="font-semibold text-sm text-[var(--color-text-heading)] group-hover:text-[var(--color-primary)] transition-colors line-clamp-2">{r.title}</h4>
                <p class="text-xs text-[var(--color-text-muted)] mt-2 line-clamp-2">{r.description}</p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Newsletter CTA -->
      <section class="newsletter-cta mt-12">
        <div class="max-w-2xl mx-auto text-center py-12 px-4">
          <h2 class="text-2xl font-bold mb-3">🚀 Get Expert {siteConfig.niche || catLabel} Guides Weekly</h2>
          <p class="mb-6">Join 2,000+ readers. Free tips, tools, and strategies delivered every Friday.</p>
          <form class="flex gap-2 max-w-md mx-auto" onsubmit="event.preventDefault(); this.querySelector('button').textContent='✓ Subscribed!';">
            <input type="email" placeholder="your@email.com" required class="flex-1 px-4 py-3 rounded-lg" />
            <button type="submit" class="px-6 py-3 rounded-lg font-semibold">Subscribe</button>
          </form>
          <p class="text-xs mt-3 opacity-70">No spam. Unsubscribe anytime.</p>
        </div>
      </section>
    </article>

    <!-- Sidebar -->
    <aside class="lg:col-span-4">
      <div class="sticky top-24 space-y-6">
        <!-- Table of Contents -->
        {tocItems.length > 0 && (
          <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-2xl p-5">
            <h3 class="font-semibold text-sm text-[var(--color-text-heading)] mb-3 flex items-center gap-2">
              <svg class="w-4 h-4 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
              On This Page
            </h3>
            <nav class="space-y-1">
              {tocItems.map(item => (
                <a href={`#${item.id}`} class={`toc-link ${item.level === 3 ? 'pl-6' : ''}`}>{item.text}</a>
              ))}
            </nav>
          </div>
        )}

        <!-- Ad slot -->
        <div class="ad-slot">
          <span>Advertisement</span>
        </div>

        <!-- Popular posts -->
        <div class="bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-2xl p-5">
          <h3 class="font-semibold text-sm text-[var(--color-text-heading)] mb-4 flex items-center gap-2">
            <svg class="w-4 h-4 text-[var(--color-accent)]" fill="currentColor" viewBox="0 0 20 20"><path d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z"/></svg>
            Trending
          </h3>
          <ul class="space-y-3">
            {allArticles.slice(0, 6).map((post, i) => (
              <li class="flex gap-3">
                <span class="flex-shrink-0 w-6 h-6 rounded-lg bg-[var(--color-bg-alt)] flex items-center justify-center text-xs font-bold text-[var(--color-primary)]">{i + 1}</span>
                <a href={`/${post.slug}`} class="text-sm text-[var(--color-text)] hover:text-[var(--color-primary)] transition-colors line-clamp-2">{post.title}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Cross-site links -->
        <CrossSiteLinks currentSiteNiche={siteConfig.niche || ''} currentSiteKeywords={siteConfig.keywords || []} />

        <!-- Sidebar Newsletter -->
        <div class="bg-gradient-to-br from-[var(--color-primary)]/5 to-[var(--color-accent)]/5 border border-[var(--color-primary)]/20 rounded-2xl p-5">
          <h3 class="font-semibold text-sm text-[var(--color-text-heading)] mb-2">📬 Stay in the Loop</h3>
          <p class="text-xs text-[var(--color-text-muted)] mb-3">Get the latest {siteConfig.niche || ''} tips delivered weekly.</p>
          <form class="space-y-2" onsubmit="event.preventDefault(); this.querySelector('button').textContent='✓ Done!';">
            <input type="email" placeholder="your@email.com" required
              class="w-full px-3 py-2 text-sm border border-[var(--color-border)] rounded-lg bg-[var(--color-bg)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]" />
            <button type="submit" class="btn-primary w-full text-xs">Subscribe Free</button>
          </form>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>
